
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5435/mindbridge

# ── AUTH (required) ───────────────────────────────────────────
# For local dev, the value below is fine. Generate a random string for production.
# Example generator: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI (optional locally — fallback responses work without it) ─
# Get your free key: https://aistudio.google.com/app/apikey
# Sign in with Google → Create API key → paste below
GEMINI_API_KEY=Paste here

# ── APP (defaults are fine for localhost) ─────────────────────
CORS_ORIGINS=http://localhost:3000
CORPUS_PATH=./corpus/mental_health_corpus.json
APP_ENV=development

# ── REDIS (conversation memory) ───────────────────────────────
REDIS_URL=redis://localhost:6380
